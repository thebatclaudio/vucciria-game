{
  "name": "vucciria-game",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Multiplayer drinking board game — P2P, no backend, no accounts.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "prefetch:noto": "node scripts/fetch-noto.mjs",
    "audit:noto": "node scripts/audit-noto.mjs"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.19.4",
    "framer-motion": "^11.11.17",
    "i18next": "^23.16.4",
    "i18next-browser-languagedetector": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.1",
    "react-router-dom": "^6.28.0",
    "trystero": "^0.20.0",
    "y-indexeddb": "^9.0.12",
    "yjs": "^13.6.20",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "happy-dom": "^15.11.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@9.12.0"
}
