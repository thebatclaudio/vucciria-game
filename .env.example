# VucciriaGame environment variables
# Copy this file to `.env.local` and fill in if needed.

# Set this when deploying to GitHub Pages under a repo subpath,
# e.g. https://username.github.io/vucciria-game/
# BASE_PATH=/vucciria-game-v2.0/

# Optional: override the Trystero P2P discovery strategy (default: nostr).
# Supported: nostr | mqtt | torrent
#
# - nostr   (default) Uses public Nostr relays. Zero config, but the public
#           relays can be slow or blocked on restrictive networks.
# - mqtt    Uses public MQTT brokers. Often more reliable on corporate Wi-Fi.
# - torrent Uses WebTorrent trackers. Good fallback when nostr/mqtt are blocked.
#
# Vite tree-shakes the unused strategies out of the bundle at build time, so
# switching is free in production.
# VITE_TRYSTERO_STRATEGY=nostr

# Optional: comma-separated relay/broker/tracker URLs for the chosen strategy.
# Overrides the strategy's default list. Examples:
#   Nostr:   VITE_TRYSTERO_RELAYS=wss://relay.damus.io,wss://nos.lol
#   MQTT:    VITE_TRYSTERO_RELAYS=wss://broker.emqx.io:8084/mqtt
#   Torrent: VITE_TRYSTERO_RELAYS=wss://tracker.openwebtorrent.com
# VITE_TRYSTERO_RELAYS=
