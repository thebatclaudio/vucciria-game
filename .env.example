# VucciriaGame environment variables
# Copy this file to `.env.local` and fill in if needed.

# Set this when deploying to GitHub Pages under a repo subpath,
# e.g. https://username.github.io/vucciria-game/
# BASE_PATH=/vucciria-game-v2.0/

# Optional: override the Trystero strategy (default: nostr).
# Valid: nostr | mqtt | torrent | firebase | supabase | ipfs | ws-relay
# VITE_TRYSTERO_STRATEGY=nostr

# Optional: comma-separated relay URLs for the chosen strategy.
# VITE_TRYSTERO_RELAYS=
